// ============================================================
// FlickSwiper — Firestore Security Rules
// ============================================================
//
// HOW TO DEPLOY:
// 1. Go to Firebase Console → Firestore Database → Rules
// 2. Delete the existing content
// 3. Paste this entire file
// 4. Click "Publish"
//
// COMPOSITE INDEX NEEDED:
// After publishing rules, go to Firestore → Indexes → Composite
// Create: Collection = "follows", Fields = followerUID ASC + followedAt DESC
// (Firebase may auto-prompt this when you first query)
//
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------
    // Users: only the profile owner can read/write their own doc.
    // Owner names on followed lists are denormalized into
    // publishedLists.ownerDisplayName — no cross-user profile
    // reads needed.
    // ---------------------------------------------------------
    match /users/{uid} {
      allow read: if request.auth != null
                  && request.auth.uid == uid;
      allow create: if request.auth != null
                    && request.auth.uid == uid;
      allow update: if request.auth != null
                    && request.auth.uid == uid;
      allow delete: if request.auth != null
                    && request.auth.uid == uid;

      // ---------------------------------------------------
      // Cloud Sync Subcollections
      // Only the owning user can read/write their own data.
      // 10KB size cap blocks storage exhaustion attacks while
      // leaving headroom for legitimate docs (~3KB max).
      // ---------------------------------------------------

      match /swipedItems/{itemId} {
        allow read: if request.auth != null
                    && request.auth.uid == uid;
        allow write: if request.auth != null
                     && request.auth.uid == uid
                     && request.resource.size() < 10240;
      }

      match /userLists/{listId} {
        allow read: if request.auth != null
                    && request.auth.uid == uid;
        allow write: if request.auth != null
                     && request.auth.uid == uid
                     && request.resource.size() < 10240;
      }

      match /listEntries/{entryId} {
        allow read: if request.auth != null
                    && request.auth.uid == uid;
        allow write: if request.auth != null
                     && request.auth.uid == uid
                     && request.resource.size() < 10240;
      }
    }

    // ---------------------------------------------------------
    // Published Lists: any authenticated user can read
    // (needed for following via shared links).
    // Only the list owner can create, update, or delete.
    // ---------------------------------------------------------
    match /publishedLists/{listId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.data.ownerUID == request.auth.uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 200
                    && request.resource.data.items is list
                    && request.resource.data.items.size() <= 500
                    && request.resource.data.ownerDisplayName is string
                    && request.resource.data.ownerDisplayName.size() <= 200
                    && request.resource.data.isActive is bool
                    && (!('description' in request.resource.data.keys()) || (request.resource.data.description is string && request.resource.data.description.size() <= 2000))
                    && (!('itemCount' in request.resource.data.keys()) || request.resource.data.itemCount == request.resource.data.items.size());

      allow update: if request.auth != null
                    && resource.data.ownerUID == request.auth.uid
                    && request.resource.data.ownerUID == resource.data.ownerUID
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 200
                    && request.resource.data.items is list
                    && request.resource.data.items.size() <= 500
                    && request.resource.data.isActive is bool
                    && (!('ownerDisplayName' in request.resource.data.keys()) || (request.resource.data.ownerDisplayName is string && request.resource.data.ownerDisplayName.size() <= 200))
                    && (!('description' in request.resource.data.keys()) || (request.resource.data.description is string && request.resource.data.description.size() <= 2000))
                    && (!('itemCount' in request.resource.data.keys()) || request.resource.data.itemCount == request.resource.data.items.size());

      allow delete: if request.auth != null
                    && resource.data.ownerUID == request.auth.uid;
    }

    // ---------------------------------------------------------
    // Follows: users can only read their own follows.
    // Users can only create follows for themselves, and only
    // for lists that actually exist.
    // Users can only delete their own follows.
    // No updates allowed (follows are immutable — create or delete).
    // ---------------------------------------------------------
    match /follows/{followId} {
      allow read: if request.auth != null
                  && resource.data.followerUID == request.auth.uid;

      allow create: if request.auth != null
                    && request.resource.data.followerUID == request.auth.uid
                    && request.resource.data.listID is string
                    && request.resource.data.followedAt is timestamp
                    && exists(/databases/$(database)/documents/publishedLists/$(request.resource.data.listID));

      allow delete: if request.auth != null
                    && resource.data.followerUID == request.auth.uid;

      // No update — follows are create-or-delete only
      allow update: if false;
    }
  }
}
